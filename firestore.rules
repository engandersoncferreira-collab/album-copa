rules_version = '2';

// ============================================================
// Regras de Segurança do Firestore — Álbum Copa 2026
// Cole este conteúdo no Console do Firebase:
//   Firestore Database  ->  aba "Regras"  ->  Publicar
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Lê o doc do próprio usuário p/ checar se é admin (campo role == 'admin')
    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---- Usuários ----
    // read liberado p/ qualquer logado: o ADMIN precisa LISTAR todos,
    // e o RANKING precisa ler apelido/cidade dos outros participantes.
    match /users/{uid} {
      allow read:   if signedIn();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();   // admin banir/reativar
      allow delete: if isAdmin();
    }

    // ---- Coleção de figurinhas (uma por usuário) ----
    match /colecoes/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    // ---- Apostas do bolão (uma por usuário) ----
    // read liberado p/ logado: o ranking lista as apostas de todos.
    match /bolao_apostas/{uid} {
      allow read:  if signedIn();
      allow write: if request.auth.uid == uid || isAdmin();
    }

    // ---- Config/resultados do bolão (doc "dados") ----
    match /bolao_meta/{doc} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // ---- Bloqueios entre usuários ----
    match /bloqueios/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    // ---- Chats (1 a 1) e mensagens ----
    match /chats/{chatId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.participantes;
      allow create:       if signedIn() && request.auth.uid in request.resource.data.participantes;

      match /mensagens/{msgId} {
        allow read, create, update: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;
      }
    }

    // ---- Mensagens para o desenvolvedor ----
    match /contato_dev/{doc} {
      allow create:               if signedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
